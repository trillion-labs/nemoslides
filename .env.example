# Required: OpenRouter powers baseline (Nemotron-3-Nano, -Super), teacher (GLM-5.1),
# and the judge (Gemini 3 Flash) in single-provider mode. Get a key at openrouter.ai.
OPENROUTER_API_KEY=

# Required for image resolution during deck rendering. Bank fallback at
# data/image_bank.json covers missing queries. Get a key at unsplash.com/developers.
UNSPLASH_ACCESS_KEY=

# Optional: direct Google API for the PPTEval judge. If unset, judge falls back
# to Gemini 3 Flash via OPENROUTER_API_KEY.
GEMINI_API_KEY=

# Optional: only used by nemoslides.pipeline.qualitative_check (legacy hour-1 teacher check).
# Not required for data synthesis, training, or eval.
OPENAI_API_KEY=

# Optional demo overrides. If unset, the demo app falls back to OPENAI_API_KEY
# and model gpt-5.4. Set DEMO_OPENAI_BASE_URL later when swapping to an
# OpenAI-compatible endpoint.
DEMO_OPENAI_API_KEY=
DEMO_MODEL=gpt-5.4
DEMO_OPENAI_BASE_URL=
DEMO_REASONING_EFFORT=medium

# Optional: secondary image provider. Unused by default paths.
PEXELS_API_KEY=
